generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ProductType {
  FEED
  MEDICINE
  EGG
  CHICKEN
}

enum TransactionType {
  PURCHASE
  SALE
}

enum TransactionStatus {
  DRAFT
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  MOBILE_MONEY
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
  CANCELLED
}

enum StockMovementType {
  OPENING
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  WASTAGE
  PRODUCTION
}

enum LedgerEntryType {
  OPENING_BALANCE
  SALE
  PURCHASE
  PAYMENT_RECEIVED
  PAYMENT_PAID
  PURCHASE_RETURN
  SALE_RETURN
  STOCK_ADJUSTMENT
  DUE_ADJUSTMENT
}

enum AdjustmentType {
  AUTO_DUE_ADJUSTMENT
  DISCOUNT
  ROUNDING
  OVERPAYMENT
}

enum ReportType {
  LEDGER
  PAYMENT
  STOCK
  SALES
  PURCHASES
  PROFIT_LOSS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  parties         Party[]
  products        Product[]
  transactions    Transaction[]
  payments        Payment[]
  ledgerEntries   LedgerEntry[]
  reports         Report[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Party {
  id            Int       @id @default(autoincrement())
  name          String
  phone         String?
  email         String?
  address       String?
  partyType     PartyType @default(BOTH)
  taxNumber     String?
  creditLimit   Decimal?  @db.Decimal(12, 2)
  openingBalance Decimal  @default(0) @db.Decimal(12, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdById   String?
  createdBy     User?     @relation(fields: [createdById], references: [id])

  transactions  Transaction[]
  payments      Payment[]
  ledgerEntries LedgerEntry[]
  dueAdjustments DueAdjustment[]

  @@index([name])
}

model ProductCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  description String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  Product[]

  @@index([name])
}

model Product {
  id                    Int        @id @default(autoincrement())
  code                  String     @unique
  name                  String
  productType           ProductType
  unit                  String
  categoryId            Int?
  category              ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  defaultPurchasePrice Decimal?   @db.Decimal(12, 2)
  defaultSellingPrice   Decimal?   @db.Decimal(12, 2)
  barcode               String?
  imageUrl              String?
  lowStockThreshold     Decimal?   @db.Decimal(12, 2)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  createdById           String?
  createdBy             User?      @relation(fields: [createdById], references: [id])

  transactionItems      TransactionItem[]
  stockMovements        StockMovement[]
  stockBalance          StockBalance?

  @@index([productType, name])
}

model StockBalance {
  id               Int      @id @default(autoincrement())
  productId        Int      @unique
  quantityOnHand   Decimal  @default(0) @db.Decimal(12, 2)
  reservedQuantity Decimal  @default(0) @db.Decimal(12, 2)
  averageCost      Decimal? @db.Decimal(12, 2)
  lastUpdatedAt    DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id            Int               @id @default(autoincrement())
  productId     Int
  transactionId Int?
  movementType  StockMovementType
  quantity      Decimal           @db.Decimal(12, 2)
  unitCost      Decimal?          @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime          @default(now())

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

model Transaction {
  id               Int               @id @default(autoincrement())
  transactionType  TransactionType
  partyId          Int
  transactionDate  DateTime          @default(now())
  invoiceNumber    String            @unique
  referenceNumber  String?
  status           TransactionStatus @default(COMPLETED)
  subtotal         Decimal           @db.Decimal(12, 2)
  discount         Decimal           @default(0) @db.Decimal(12, 2)
  tax              Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount      Decimal           @db.Decimal(12, 2)
  paidAmount       Decimal           @default(0) @db.Decimal(12, 2)
  dueAmount        Decimal           @default(0) @db.Decimal(12, 2)
  dueDate          DateTime?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdById      String?
  createdBy        User?             @relation(fields: [createdById], references: [id])
  party            Party             @relation(fields: [partyId], references: [id], onDelete: Restrict)

  items            TransactionItem[]
  payments         PaymentAllocation[]
  stockMovements   StockMovement[]
  ledgerEntries    LedgerEntry[]
  dueAdjustments   DueAdjustment[]

  @@index([partyId, transactionDate])
}

model TransactionItem {
  id           Int     @id @default(autoincrement())
  transactionId Int
  productId    Int
  quantity     Decimal @db.Decimal(12, 2)
  unitPrice    Decimal @db.Decimal(12, 2)
  lineTotal    Decimal @db.Decimal(12, 2)
  taxAmount    Decimal @default(0) @db.Decimal(12, 2)
  description  String?

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([transactionId])
}

model Payment {
  id               Int            @id @default(autoincrement())
  partyId          Int
  paymentDate      DateTime       @default(now())
  paymentMethod    PaymentMethod
  amount           Decimal        @db.Decimal(12, 2)
  referenceNumber  String?
  status           PaymentStatus  @default(COMPLETED)
  notes            String?
  createdAt        DateTime       @default(now())

  createdById      String?
  createdBy        User?          @relation(fields: [createdById], references: [id])
  party            Party          @relation(fields: [partyId], references: [id], onDelete: Restrict)

  allocations      PaymentAllocation[]
  ledgerEntries    LedgerEntry[]

  @@index([partyId, paymentDate])
}

model PaymentAllocation {
  id              Int      @id @default(autoincrement())
  paymentId       Int
  transactionId   Int
  amount          Decimal  @db.Decimal(12, 2)
  allocationDate  DateTime @default(now())

  payment     Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([paymentId, transactionId])
}

model LedgerEntry {
  id               Int            @id @default(autoincrement())
  entryDate        DateTime       @default(now())
  partyId          Int?
  transactionId    Int?
  paymentId        Int?
  entryType        LedgerEntryType
  amount           Decimal        @db.Decimal(12, 2)
  runningBalance   Decimal        @db.Decimal(12, 2)
  description      String?
  referenceNumber  String?

  party         Party?         @relation(fields: [partyId], references: [id], onDelete: SetNull)
  transaction   Transaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  payment       Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?          @relation(fields: [createdById], references: [id])

  @@index([partyId, entryDate])
}

model DueAdjustment {
  id               Int            @id @default(autoincrement())
  transactionId    Int
  partyId          Int
  adjustmentType   AdjustmentType
  amount           Decimal        @db.Decimal(12, 2)
  reason           String?
  isAuto           Boolean        @default(true)
  createdAt        DateTime       @default(now())

  transaction      Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  party            Party          @relation(fields: [partyId], references: [id], onDelete: Restrict)
}

model Report {
  id            Int       @id @default(autoincrement())
  reportType    ReportType
  title         String
  generatedAt   DateTime  @default(now())
  filters       Json?
  summary       Json?

  createdById   String?
  createdBy     User?     @relation(fields: [createdById], references: [id])

  @@index([reportType, generatedAt])
}
